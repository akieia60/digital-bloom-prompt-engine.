# Digital Bloom Environment Variables
# Copy to .env.local for development

# Supabase Configuration
VITE_SUPABASE_URL=https://ljzlkphwkgyavqmoremg.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe Configuration (Frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Configuration (Backend/API)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Monique live chat
OPENAI_API_KEY=sk_your_openai_api_key_here
MONIQUE_CHAT_MODEL=gpt-4o-mini

# Stripe Price IDs (Create these in Stripe Dashboard)
STRIPE_BASIC_PRICE_ID=price_basic_monthly_id_here
STRIPE_PREMIUM_PRICE_ID=price_premium_monthly_id_here  
STRIPE_CHURCH_PRICE_ID=price_church_monthly_id_here

# Email Configuration for Reminders
EMAIL_FROM=reminders@digitalbloom.com
EMAIL_PASSWORD=your_gmail_app_password_here

# Cron Job Security
CRON_SECRET=random_secret_for_cron_job_auth

# App URLs
VERCEL_URL=https://digitalbloom.vercel.app
NEXT_PUBLIC_APP_URL=https://digitalbloom.vercel.app