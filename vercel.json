{
  "functions": {
    "api/stripe-webhook.js": {
      "runtime": "nodejs20.x"
    },
    "api/create-checkout.js": {
      "runtime": "nodejs20.x"
    },
    "api/create-portal.js": {
      "runtime": "nodejs20.x"
    },
    "api/process-reminders.js": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/process-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}